{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inventario-hogar",
  "version": "0.1.0",
  "identifier": "com.inventario.hogar",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Inventario Hogar",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "identifier": "com.inventario.hogar",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "",
    "longDescription": "",
    "macOS": {},
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {},
    "android": {
      "minSdkVersion": 23,
      "targetSdkVersion": 34
    }
  },
  "plugins": {
    "fs": {
      "scope": ["$APP_DATA/**"]
    }
  }
}